# Environment Configuration Template
# Copy this to .env.local and fill in actual values

# Site Configuration
SITE_NAME="DevNinja AI Learning"
SITE_URL="https://ailearning.devninja.in"
SITE_DESCRIPTION="Interactive AI Learning Platform"

# Analytics (Optional)
# ANALYTICS_ID=""

# Content Management (If needed)
# CMS_API_KEY=""
# CMS_URL=""

# Build Configuration
NODE_ENV=development

# Feature Flags
ENABLE_DARK_MODE=true
ENABLE_ANALYTICS=false
ENABLE_INTERACTIVE_DEMOS=true
